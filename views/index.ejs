    </div>
    <!--After Quiz Content-->
    <div class="results-container">
      <div class="center-container">
        <h1 class="noto-sans-sc-normal">Results</h1>
        <div class="results-options-container">
          <h2 class="noto-sans-sc-normal result-header">You scored 20/20!</h2>
          <button class="pushable noto-sans-sc-normal again-button">
            <span class="front">Try Again</span>
          </button>
        </div>
      </div>
