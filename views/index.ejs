          <!--Current slider layout-->
          <div class="hsk-slider-container">

            <input
              type="range"
              min="1"
              max="7"
              step="1"
              value="1"
              class="hsk-slider"
            />

            <div class="hsk-ticks noto-sans-sc-normal">
              <span>1</span>
              <span>2</span>
              <span>3</span>
              <span>4</span>
              <span>5</span>
              <span>6</span>
              <span>7-9</span>
            </div>
          </div>

          <button class="pushable noto-sans-sc-normal submit-levels">
            <span class="front">Practice</span>
          </button>
          <button class="pushable noto-sans-sc-normal speed-button">
            <span class="front">Speed Mode (all levels)</span>
          </button>
        </div>
      </div>
    </div>
    <!-- Main quiz content -->
    <div class="sentence-container">
      <div class="timer"></div>
      <div class="sentence-div"></div>
      <div class="buttons">
        <!-- <button class="menu-button sound">
          <img class="icon" src="/images/icons/music.svg" />
